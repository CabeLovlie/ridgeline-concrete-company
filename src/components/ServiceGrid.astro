---
import { Truck, Grid, Layers, Building2, Home, Hammer } from '@lucide/astro';

interface Service {
  title: string;
  description: string;
  icon: 'Truck' | 'Grid' | 'Layers' | 'Building2' | 'Home' | 'Hammer';
  href: string;
}

interface Props {
  showCta?: boolean;
}

const { showCta = true } = Astro.props;

const services: Service[] = [
  {
    title: 'Driveways',
    description: 'Full replacement and new pours. Rebar-reinforced for lasting results.',
    icon: 'Truck',
    href: '/work#driveways',
  },
  {
    title: 'Patios & Outdoor Slabs',
    description: 'Flat finish, exposed aggregate, or stamped. Any size.',
    icon: 'Grid',
    href: '/work#patios',
  },
  {
    title: 'Stamped Concrete',
    description: 'Wood grain, slate, ashlar — decorative concrete that outperforms wood.',
    icon: 'Layers',
    href: '/work#stamped',
  },
  {
    title: 'Foundations & Slabs',
    description: 'Shop floors, ADU foundations, stem walls, and garage slabs.',
    icon: 'Building2',
    href: '/work#foundations',
  },
  {
    title: 'Sidewalks & Pathways',
    description: 'Residential walkways, front porches, steps, and curbing.',
    icon: 'Home',
    href: '/work#sidewalks',
  },
  {
    title: 'Concrete Repair',
    description: 'Cracked or sunken sections replaced. Old concrete demo and haul-off included.',
    icon: 'Hammer',
    href: '/work#repair',
  },
];

const icons = { Truck, Grid, Layers, Building2, Home, Hammer };
---

<section class="service-grid-section fade-up">
  <div class="container">
    <div class="speed-lines speed-lines--wide">
      <span></span>
      <span></span>
      <span></span>
    </div>
    <h2 class="section-heading">WHAT WE BUILD</h2>

    <div class="service-grid">
      {services.map((service) => {
        const Icon = icons[service.icon];
        return (
          <a href={service.href} class="service-card">
            <div class="service-card__icon">
              <Icon size={24} color="#e85d04" />
            </div>
            <h3 class="service-card__title">{service.title}</h3>
            <p class="service-card__desc">{service.description}</p>
          </a>
        );
      })}
    </div>

    {showCta && (
      <p class="service-grid__cta">
        <a href="/services" class="text-link">View All Services →</a>
      </p>
    )}
  </div>
</section>

<style>
  .service-grid-section {
    padding: 5rem 0;
    background-color: var(--color-bg);
  }

  .service-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin-top: 2.5rem;
  }

  .service-card {
    display: block;
    background-color: var(--color-surface);
    border-left: 2px solid #4a4a4a;
    padding: 24px;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s ease;
  }

  .service-card:hover {
    border-left-color: var(--color-accent);
  }

  .service-card__icon {
    margin-bottom: 1rem;
  }

  .service-card__title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 22px;
    letter-spacing: 0.02em;
    margin: 0 0 0.5rem;
    color: var(--color-text);
  }

  .service-card__title::after {
    content: '';
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .service-card:hover .service-card__title::after {
    content: ' →';
    opacity: 1;
    color: var(--color-accent);
  }

  .service-card__desc {
    font-size: 14px;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .service-grid__cta {
    margin: 2.5rem 0 0;
    text-align: center;
    font-size: 15px;
  }

  @media (min-width: 640px) {
    .service-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .service-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
