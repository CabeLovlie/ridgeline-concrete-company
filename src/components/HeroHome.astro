---
import { ChevronDown } from '@lucide/astro';
---

<section class="hero">
  <img
    src="/images/rupp-construction-drone03.jpg"
    alt="Finished residential driveway overhead view with clean concrete"
    class="hero__bg"
    loading="eager"
  />
  <div class="hero__overlay"></div>

  <div class="hero__content">
    <p class="hero__eyebrow">ENUMCLAW, WA</p>
    <h1 class="hero__title">CONCRETE THAT LASTS.</h1>
    <p class="hero__subhead">Driveways. Patios. Foundations. Stamped Concrete.</p>
    <div class="hero__ctas">
      <a href="/contact" class="btn-primary">Get a Free Quote</a>
      <a href="/work" class="btn-secondary">See Our Work</a>
    </div>
  </div>

  <a href="#stats" class="hero__scroll scroll-indicator" aria-label="Scroll down">
    <ChevronDown size={28} color="#e85d04" />
  </a>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    margin-top: 101px;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0, 0, 0, 0.55) 0%, rgba(0, 0, 0, 0.75) 100%);
  }

  .hero__content {
    position: relative;
    z-index: 1;
    padding: 2rem 1.5rem;
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
    text-align: center;
  }

  .hero__eyebrow {
    font-size: 12px;
    color: var(--color-accent);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin: 0 0 1rem;
    font-weight: 500;
  }

  .hero__title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 48px;
    letter-spacing: 0.02em;
    line-height: 1;
    margin: 0 0 1.25rem;
    color: var(--color-text);
  }

  .hero__subhead {
    font-size: 18px;
    color: var(--color-text-muted);
    margin: 0 0 2rem;
  }

  .hero__ctas {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
  }

  .hero__scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  @media (min-width: 768px) {
    .hero__content {
      text-align: left;
    }

    .hero__title {
      font-size: 72px;
    }

    .hero__subhead {
      font-size: 20px;
    }

    .hero__ctas {
      flex-direction: row;
      justify-content: flex-start;
    }
  }
</style>
