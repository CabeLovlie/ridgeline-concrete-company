---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/services', label: 'Services' },
  { href: '/work', label: 'Our Work' },
  { href: '/service-area', label: 'Service Area' },
  { href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath === href || currentPath.startsWith(href + '/');
}
---

<header class="nav-header">
  <nav class="nav" aria-label="Main navigation">
    <a href="/" class="nav__logo-link">
      <img
        src="/images/ridgeline-logo.png"
        alt="Ridgeline Concrete Co."
        class="nav__logo"
        width="44"
        height="44"
      />
    </a>

    <ul class="nav__links">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={['nav__link', { 'nav__link--active': isActive(link.href) }]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <a href="/contact" class="nav__cta">Get a Quote</a>

    <button class="nav__hamburger" aria-label="Open menu" aria-expanded="false" id="nav-toggle">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </nav>

  <div class="nav__overlay" id="nav-overlay" aria-hidden="true">
    <ul class="nav__overlay-links">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={['nav__overlay-link', { 'nav__overlay-link--active': isActive(link.href) }]}
          >
            {link.label}
          </a>
        </li>
      ))}
      <li>
        <a href="/contact" class="nav__overlay-cta">Get a Quote</a>
      </li>
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('nav-toggle');
  const overlay = document.getElementById('nav-overlay');

  toggle?.addEventListener('click', () => {
    const isOpen = overlay?.classList.toggle('nav__overlay--open');
    toggle.setAttribute('aria-expanded', String(isOpen));
    toggle.setAttribute('aria-label', isOpen ? 'Close menu' : 'Open menu');
    document.body.style.overflow = isOpen ? 'hidden' : '';
  });

  overlay?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      overlay.classList.remove('nav__overlay--open');
      toggle?.setAttribute('aria-expanded', 'false');
      toggle?.setAttribute('aria-label', 'Open menu');
      document.body.style.overflow = '';
    });
  });
</script>

<style>
  .nav-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1.5rem;
    background-color: rgba(15, 15, 15, 0.95);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--color-border);
  }

  .nav__logo {
    height: 44px;
    width: auto;
    object-fit: contain;
  }

  .nav__links {
    display: none;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 1.75rem;
    align-items: center;
  }

  .nav__link {
    font-size: 14px;
    font-weight: 500;
    color: var(--color-text);
    transition: color 200ms ease;
  }

  .nav__link:hover,
  .nav__link--active {
    color: var(--color-accent);
  }

  .nav__cta {
    display: none;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 15px;
    letter-spacing: 0.05em;
    background-color: var(--color-accent);
    color: #fff;
    padding: 0.5rem 1.25rem;
    border-radius: 4px;
    transition: background-color 200ms ease;
  }

  .nav__cta:hover {
    background-color: var(--color-accent-dim);
  }

  .nav__hamburger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 40px;
    height: 40px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
  }

  .nav__hamburger span {
    display: block;
    height: 2px;
    background-color: var(--color-text);
    transition: transform 200ms ease, opacity 200ms ease;
  }

  .nav__overlay {
    position: fixed;
    inset: 0;
    top: 61px;
    background-color: rgba(15, 15, 15, 0.98);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: opacity 300ms ease, visibility 300ms ease;
  }

  .nav__overlay--open {
    opacity: 1;
    visibility: visible;
  }

  .nav__overlay-links {
    list-style: none;
    margin: 0;
    padding: 0;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .nav__overlay-link {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 32px;
    letter-spacing: 0.05em;
    color: var(--color-text);
    transition: color 200ms ease;
  }

  .nav__overlay-link:hover,
  .nav__overlay-link--active {
    color: var(--color-accent);
  }

  .nav__overlay-cta {
    display: inline-block;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 20px;
    background-color: var(--color-accent);
    color: #fff;
    padding: 0.75rem 2rem;
    border-radius: 4px;
    margin-top: 1rem;
  }

  @media (min-width: 1024px) {
    .nav__links {
      display: flex;
    }

    .nav__cta {
      display: inline-block;
    }

    .nav__hamburger {
      display: none;
    }
  }
</style>
