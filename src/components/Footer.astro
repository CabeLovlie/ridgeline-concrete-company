---
import { Instagram, Facebook } from '@lucide/astro';

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/services', label: 'Services' },
  { href: '/work', label: 'Our Work' },
  { href: '/service-area', label: 'Service Area' },
  { href: '/contact', label: 'Contact' },
];

const cities = [
  'Auburn', 'Federal Way', 'Renton', 'Kent',
  'Maple Valley', 'Covington', 'Bonney Lake', 'Sumner', 'Buckley',
];
---

<footer class="footer">
  <div class="footer__speed-lines">
    <div class="speed-lines speed-lines--footer">
      <span></span>
      <span></span>
      <span></span>
    </div>
  </div>

  <div class="container footer__grid">
    <div class="footer__col">
      <img
        src="/images/ridgeline-logo.png"
        alt="Ridgeline Concrete Co."
        class="footer__logo"
        width="56"
        height="56"
        loading="lazy"
      />
      <p class="footer__tagline">Built right. Every pour.</p>
    </div>

    <div class="footer__col">
      <h3 class="footer__heading">Quick Links</h3>
      <ul class="footer__links">
        {navLinks.map((link) => (
          <li>
            <a href={link.href} class="footer__link">{link.label}</a>
          </li>
        ))}
      </ul>
    </div>

    <div class="footer__col">
      <h3 class="footer__heading">Contact</h3>
      <p class="footer__contact-item">
        <a href="tel:+12535550148" class="footer__phone">(253) 555-0148</a>
      </p>
      <p class="footer__cities">
        Serving {cities.join(' · ')}
      </p>
      <div class="footer__social">
        <a
          href="https://www.instagram.com"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Ridgeline Concrete Co. on Instagram"
          class="footer__social-link"
        >
          <Instagram size={20} />
        </a>
        <a
          href="https://www.facebook.com"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Ridgeline Concrete Co. on Facebook"
          class="footer__social-link"
        >
          <Facebook size={20} />
        </a>
      </div>
    </div>
  </div>

  <div class="footer__bar">
    <p class="footer__disclaimer">
      Portfolio demo by Cabriel Lovlie Web Design. Ridgeline Concrete Co. is a fictional contractor brand created to showcase website design, layout, and conversion strategy. It does not represent an active business.
    </p>
    <p>
      © 2026 Ridgeline Concrete Co. · South King County, WA
    </p>
  </div>
</footer>

<style>
  .footer {
    background-color: #111111;
    padding-top: 0;
    padding-bottom: 0;
  }

  .footer__speed-lines {
    border-top: 1px solid var(--color-border);
    padding: 0 1.5rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    padding-top: 3rem;
    padding-bottom: 3rem;
  }

  .footer__logo {
    height: 56px;
    width: auto;
    margin-bottom: 1rem;
  }

  .footer__tagline {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 20px;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    margin: 0;
  }

  .footer__heading {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 18px;
    letter-spacing: 0.05em;
    margin: 0 0 1rem;
    color: var(--color-text);
  }

  .footer__links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer__link {
    font-size: 14px;
    color: var(--color-text-muted);
    transition: color 200ms ease;
  }

  .footer__link:hover {
    color: var(--color-accent);
  }

  .footer__contact-item {
    margin: 0 0 0.5rem;
    font-size: 14px;
  }

  .footer__phone {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 24px;
    color: var(--color-accent);
    transition: color 200ms ease;
  }

  .footer__phone:hover {
    color: var(--color-accent-dim);
  }

  .footer__cities {
    font-size: 12px;
    color: var(--color-text-muted);
    margin: 1rem 0 0;
    line-height: 1.6;
  }

  .footer__social {
    display: flex;
    gap: 1rem;
    margin-top: 1rem;
  }

  .footer__social-link {
    color: var(--color-text-muted);
    transition: color 200ms ease;
  }

  .footer__social-link:hover {
    color: var(--color-accent);
  }

  .footer__bar {
    border-top: 1px solid var(--color-border);
    padding: 1.25rem 1.5rem;
    text-align: center;
  }

  .footer__disclaimer {
    font-size: 12px;
    opacity: 0.5;
    margin: 0 auto 1rem;
    font-style: italic;
    max-width: 720px;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .footer__bar p:last-child {
    margin: 0;
    font-size: 12px;
    color: var(--color-text-muted);
    font-family: 'JetBrains Mono', monospace;
  }

  @media (min-width: 768px) {
    .footer__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
