<div class="credential-bar">
  <div class="ticker-strip">
    <span class="ticker-item"><span class="ticker-check">✓</span> Licensed & Insured</span>
    <span class="ticker-divider">|</span>
    <span class="ticker-item"><span class="ticker-check">✓</span> Concrete Driveways & Patios</span>
    <span class="ticker-divider">|</span>
    <span class="ticker-item"><span class="ticker-check">✓</span> Serving South King County</span>
    <span class="ticker-divider">|</span>
    <span class="ticker-item">★★★★★ Sample Review Section</span>
  </div>
</div>

<style>
  .credential-bar {
    position: fixed;
    top: 61px;
    left: 0;
    right: 0;
    z-index: 90;
    background-color: var(--color-surface);
    min-height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    border-bottom: 1px solid var(--color-border);
  }

  .ticker-strip {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 0.25rem 0.5rem;
    padding: 0.5rem 1rem;
    font-size: 12px;
    color: var(--color-text-muted);
    width: 100%;
  }

  .ticker-check {
    color: var(--color-accent);
  }

  .ticker-divider {
    opacity: 0.4;
  }

  @media (max-width: 800px) {
    .ticker-strip {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.4rem 0.75rem;
      text-align: center;
      padding: 0.6rem 1rem;
    }

    .ticker-divider {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .ticker-strip {
      grid-template-columns: 1fr;
    }
  }
</style>
