<style>
  .credential-bar {
    position: fixed;
    top: 61px;
    left: 0;
    right: 0;
    z-index: 90;
    background-color: var(--color-surface);
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    border-bottom: 1px solid var(--color-border);
  }

  .credential-bar__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding: 0 1.5rem;
    font-size: 12px;
    color: var(--color-text-muted);
    text-align: center;
    white-space: nowrap;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    width: 100%;
  }

  .credential-bar__inner::-webkit-scrollbar {
    display: none;
  }

  .credential-bar__value {
    font-family: 'JetBrains Mono', monospace;
    color: var(--color-accent);
  }

  .credential-bar__stars {
    color: var(--color-accent);
  }

  .credential-bar__sep {
    color: var(--color-border);
    flex-shrink: 0;
  }

  .credential-bar__item {
    flex-shrink: 0;
  }
</style>
