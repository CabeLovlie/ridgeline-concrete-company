---
interface Props {
  beforeSrc: string;
  afterSrc: string;
  beforeAlt: string;
  afterAlt: string;
  caption?: string;
}

const { beforeSrc, afterSrc, beforeAlt, afterAlt, caption } = Astro.props;
---

<div class="before-after fade-up">
  <div class="before-after__panels">
    <div class="before-after__panel">
      <img src={beforeSrc} alt={beforeAlt} loading="lazy" class="before-after__img" />
      <span class="before-after__label before-after__label--before">BEFORE</span>
      <div class="before-after__tint before-after__tint--before"></div>
    </div>
    <div class="before-after__panel">
      <img src={afterSrc} alt={afterAlt} loading="lazy" class="before-after__img" />
      <span class="before-after__label before-after__label--after">AFTER</span>
      <div class="before-after__tint before-after__tint--after"></div>
    </div>
  </div>
  {caption && <p class="before-after__caption">{caption}</p>}
</div>

<style>
  .before-after__panels {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .before-after__panel {
    position: relative;
    flex: 1;
    overflow: hidden;
    aspect-ratio: 16 / 10;
  }

  .before-after__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .before-after__label {
    position: absolute;
    top: 1rem;
    left: 1rem;
    z-index: 2;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 14px;
    letter-spacing: 0.1em;
    padding: 0.25rem 0.75rem;
    border-radius: 2px;
  }

  .before-after__label--before {
    background-color: rgba(180, 40, 40, 0.85);
    color: #fff;
  }

  .before-after__label--after {
    background-color: rgba(232, 93, 4, 0.85);
    color: #fff;
  }

  .before-after__tint {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .before-after__tint--before {
    background-color: rgba(120, 30, 30, 0.25);
  }

  .before-after__tint--after {
    background-color: rgba(232, 93, 4, 0.15);
  }

  .before-after__caption {
    margin: 1rem 0 0;
    font-size: 14px;
    color: var(--color-text-muted);
    text-align: center;
  }

  @media (min-width: 768px) {
    .before-after__panels {
      flex-direction: row;
    }
  }
</style>
