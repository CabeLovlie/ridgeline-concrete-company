---
import Base from '../layouts/Base.astro';

const cities = [
  'Auburn', 'Enumclaw', 'Federal Way', 'Renton', 'Kent',
  'Maple Valley', 'Covington', 'Bonney Lake', 'Sumner', 'Buckley',
  'Black Diamond', 'Puyallup', 'Tacoma',
];
---

<Base title="Service Area | Ridgeline Concrete Co.">
  <section class="page-hero" style="height: 40vh; margin-top: 61px;">
    <img
      src="/images/rupp-construction-drone04.jpg"
      alt=""
      aria-hidden="true"
      class="page-hero__bg"
      loading="eager"
    />
    <div class="page-hero__overlay"></div>
    <div class="page-hero__content">
      <h1 class="page-hero__title">SERVICE AREA</h1>
      <p class="page-hero__subhead">
        Serving South King County and greater Puget Sound.
      </p>
    </div>
  </section>

  <section class="service-area-page fade-up">
    <div class="container">
      <div class="city-grid">
        {cities.map((city) => (
          <span class="city-badge">{city}</span>
        ))}
      </div>

      <p class="service-area-note">
        Not sure if we serve your area? Call us at{' '}
        <a href="tel:+12535550148" class="text-link">(253) 555-0148</a>
        {' '}— if we can get there, we'll quote it.
      </p>

      <div class="map-embed">
        <iframe
          src="https://maps.google.com/maps?q=South+King+County,+WA&t=&z=10&ie=UTF8&iwloc=&output=embed"
          width="100%"
          height="400"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Ridgeline Concrete Co. service area map"
        ></iframe>
      </div>
    </div>
  </section>
</Base>

<style>
  .service-area-page {
    padding: 4rem 0;
  }

  .city-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    margin-bottom: 2.5rem;
  }

  .city-badge {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    padding: 12px 20px;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 18px;
    letter-spacing: 0.05em;
    text-align: center;
    border-radius: 4px;
    color: var(--color-text);
  }

  .service-area-note {
    font-size: 15px;
    color: var(--color-text-muted);
    text-align: center;
    margin: 0 0 2.5rem;
    line-height: 1.6;
  }

  .map-embed {
    height: 400px;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    overflow: hidden;
    filter: grayscale(100%) invert(90%) contrast(85%);
  }

  .map-embed iframe {
    display: block;
    width: 100%;
    height: 100%;
  }

  @media (min-width: 640px) {
    .city-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .city-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
</style>
