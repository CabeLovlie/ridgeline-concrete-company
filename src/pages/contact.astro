---
import Base from '../layouts/Base.astro';
import ContactForm from '../components/ContactForm.astro';
---

<Base title="Get a Free Quote | Ridgeline Concrete Co.">
  <section class="page-hero" style="height: 35vh; margin-top: 61px;">
    <img
      src="/images/rupp-construction-team03.jpg"
      alt=""
      aria-hidden="true"
      class="page-hero__bg"
      loading="eager"
    />
    <div class="page-hero__overlay"></div>
    <div class="page-hero__content contact-hero__content">
      <h1 class="page-hero__title">GET A FREE QUOTE</h1>
      <p class="page-hero__subhead">
        Tell us about your project. Most estimates turned around within 24 hours.
      </p>
    </div>
  </section>

  <section class="contact-page fade-up">
    <div class="contact-page__wrapper">
      <div class="contact-page__grid">
        <div class="contact-page__form">
          <ContactForm />
        </div>

        <div class="contact-page__info">
          <h2 class="contact-page__heading">Prefer to call?</h2>
          <a href="tel:+12535550148" class="contact-page__phone">(253) 555-0148</a>
          <p class="contact-page__hours">We typically respond same day.</p>
          <img
            src="/images/rupp-construction-team03.jpg"
            alt="Concrete crew at work"
            class="w-full max-w-xs mx-auto block"
            style="border-radius: 4px;"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .contact-hero__content {
    text-align: center;
  }

  .contact-page {
    padding: 4rem 0;
  }

  .contact-page__wrapper {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .contact-page__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: start;
  }

  .contact-page__heading {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 32px;
    letter-spacing: 0.02em;
    margin: 0 0 1rem;
    color: var(--color-text);
  }

  .contact-page__phone {
    display: block;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 48px;
    color: var(--color-accent);
    margin-bottom: 1rem;
    transition: color 200ms ease;
    line-height: 1;
  }

  .contact-page__phone:hover {
    color: var(--color-accent-dim);
  }

  .contact-page__hours {
    font-size: 14px;
    color: var(--color-text-muted);
    margin: 0 0 2rem;
  }

  @media (min-width: 768px) {
    .contact-page__grid {
      grid-template-columns: 1fr 1fr;
      gap: 64px;
    }
  }
</style>
